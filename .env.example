# ---- App Settings ----
APP_SECRET_KEY=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ---- Active Directory ----
AD_SERVER=ldap://your-dc.example.com
AD_USER=CN=svc_reader,OU=Service,DC=example,DC=com
AD_PASSWORD=your-ad-password
AD_BASE_DN=DC=example,DC=com

# ---- vCenter ----
VCENTER_HOST=vcenter.example.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your-vcenter-password
VCENTER_DISABLE_SSL=true

# ---- Jira ----
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_API_TOKEN=your-jira-api-token

# ---- Confluence ----
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USER=you@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
