# ---- Active Directory (optional defaults, can be set via UI) ----
AD_SERVER=ldap://your-dc.example.com
# Optional fallback bind account (can be left blank if users provide credentials in UI)
AD_USER=
AD_PASSWORD=
AD_BASE_DN=DC=example,DC=com
AD_BATTS_GROUP_CN=batts
AD_UNIXUSERS_GROUP_CN=unixusers

# ---- vCenter (optional defaults, can be set via UI) ----
VCENTER_HOST=vcenter.example.com
# Optional fallback credentials (can be left blank if users provide domain credentials in UI)
VCENTER_USER=
VCENTER_PASSWORD=
VCENTER_DISABLE_SSL=true

# ---- Jira (optional defaults, can be set via UI) ----
